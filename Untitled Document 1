<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Portfolio | Abhishake Yadla</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">

    <!-- External CSS -->
    <link rel="stylesheet" href="styles.css">
</head>

<body>

    <!-- Navigation -->
    <nav>
        <div class="logo">Portfolio</div>

        <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#skills">Skills</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">

        <div class="hero-text">
            <h1>Abhishake Yadla</h1>

            <p>III B.Tech IT | Anil neerukonda Institute of Technology and Sciences</p>

            <p class="tagline">
                Passionate Web Developer | Creative Thinker | Lifelong Learner
            </p>

            <a href="#contact" class="btn">Contact Me</a>

        </div>

        <img src="https://via.placeholder.com/250" alt="Profile Photo">

    </section>

    <!-- About -->

    <section id="about">

        <h2>About Me</h2>

        <div class="about-container">

            <div>

                <p>
                    Hello! I am a <strong>Information Technology</strong>
                    student who enjoys creating modern websites using
                    <mark>HTML5</mark> and <mark>CSS3</mark>.
                </p>

                <p>
                    I enjoy solving real-world problems through technology and
                    continuously improve my skills in
                    <em>Web Development, UI Design, and Programming.</em>
                </p>

                <p>
                    My goal is to become a full-stack developer and contribute
                    to innovative software solutions.
                </p>

            </div>

        </div>

    </section>

    <!-- Skills -->

    <section id="skills">

        <h2>My Skills</h2>

        <div class="skills-container">

            <article class="skill-box">

                <h3>Technical Skills</h3>

                <span class="badge">HTML5</span>
                <span class="badge">CSS3</span>
                <span class="badge">Java</span>
                <span class="badge">Python</span>
                <span class="badge">SQL</span>
                <span class="badge">Bootstrap</span>

            </article>

            <article class="skill-box">

                <h3>Soft Skills</h3>

                <span class="badge">Communication</span>
                <span class="badge">Leadership</span>
                <span class="badge">Problem Solving</span>
                <span class="badge">Teamwork</span>
                <span class="badge">Creativity</span>
                <span class="badge">Time Management</span>

            </article>

        </div>

        <h3>Skill Progress</h3>

        <div class="progress">
            <div class="html">HTML - 90%</div>
        </div>

        <div class="progress">
            <div class="css">CSS - 85%</div>
        </div>

    </section>

    <!-- Projects -->

    <section id="projects">

        <h2>Projects</h2>

        <div class="project-grid">

            <div class="card">

                <h3>Portfolio Website</h3>

                <p>
                    Designed a responsive personal portfolio using HTML and CSS.
                </p>

                <a href="#">View Project</a>

            </div>

            <div class="card">

                <h3>Student Management System</h3>

                <p>
                    A Java-based application to manage student records.
                </p>

                <a href="#">View Project</a>

            </div>

        </div>

    </section>

    <!-- Contact -->

    <section id="contact">

        <h2>Contact Me</h2>

        <form>

            <label for="name">Name</label>
            <input type="text" id="name" required>

            <label for="email">Email</label>
            <input type="email" id="email" required>

            <label for="phone">Phone</label>
            <input type="tel" id="phone">

            <label for="message">Message</label>
            <textarea id="message" rows="5"></textarea>

            <button type="submit">Send Message</button>

        </form>

    </section>

    <!-- Footer -->

    <footer>

        <p>&copy; 2025 Abhishake Yadla. All Rights Reserved.</p>

        <address>
            Email: yourname@email.com
        </address>

        <div class="social">

            <a href="https://github.com/" target="_blank">GitHub</a>

            <a href="https://linkedin.com/" target="_blank">LinkedIn</a>

        </div>

    </footer>

</body>

</html>
